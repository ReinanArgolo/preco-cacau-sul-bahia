# Escrita do pipeline Python (use a conexão Pooler do Supabase em IPv4)
SUPABASE_DB_URL=postgresql+psycopg://postgres.PROJECT:PASSWORD@HOST:6543/postgres

# Leitura pelo aplicativo Next.js. A chave publishable pode aparecer no navegador.
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

COCOA_HTTP_TIMEOUT=45
COCOA_LOG_LEVEL=INFO
